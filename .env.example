# Copy to .env and adjust as needed
POSTGRES_USER=finagent
POSTGRES_PASSWORD=finagent_dev_password
POSTGRES_DB=financial_gold
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=faq_policies

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_REQUESTS=agent.requests
KAFKA_TOPIC_RESPONSES=agent.responses

# Free local LLM via Ollama (install separately: https://ollama.com)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# Embedding model (sentence-transformers, runs locally)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Service ports (host mapping)
ORCHESTRATOR_PORT=8000
DLP_PORT=8001
TEXT_TO_SQL_PORT=8002
RAG_PORT=8003

LOG_LEVEL=INFO
ENVIRONMENT=development
