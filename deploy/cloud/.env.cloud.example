# Cloud VM environment — copy to project root as .env before deploy
# cp deploy/cloud/.env.cloud.example .env

POSTGRES_USER=finagent
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=financial_gold

# Public ports (open in cloud firewall / security group)
ORCHESTRATOR_PORT=8000
MCP_SERVER_PORT=8020

# Ollama on same VM (install separately) or remote LLM endpoint
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

QDRANT_COLLECTION=faq_policies
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOG_LEVEL=INFO
ENVIRONMENT=cloud

# Optional: if using managed Kafka/Redis later
# KAFKA_BOOTSTRAP_SERVERS=your-confluent-bootstrap:9092
# REDIS_HOST=your-elasticache-endpoint
